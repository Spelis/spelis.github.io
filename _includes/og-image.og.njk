<style>
    .root {
        width: 100%;
        height: 100%;

        position: relative;

        display: flex;
        flex-direction: column;
        justify-content: flex-end;

        font-family: "Kode Mono";

        background: #151617;

        padding: 40px 60px;

        border-bottom: 20px solid #2a3039;
        border-left: 20px solid #2a3039;
    }

    .site {
				position: absolute;
				bottom: 40px;
				left: 40px;
				display: flex;
        color: #7c8894;
        font-size: 24px;
    }

    .title {
        color: #d2e7ef;
        font-size: 72px;
        line-height: 1.1;
        margin: 0;
        max-width: 900px;
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
    }

    .logo {
				display: flex;
        position: absolute;
        top: 40px;
        right: 40px;

				color: #d2e7ef;
    }

    .logo * {
				color: #d2e7ef;
				width: 88.64512px;
				height: 128px;
    }
</style>

<div class="root">
    <div class="logo">
        {{ "/assets/images/logo.svg" | embedSVG | safe }}
    </div>

    <div class="site">
        {{ siteTitle | safe }}
    </div>

    <h1 class="title">
        {{ title | safe }}
    </h1>
</div>
