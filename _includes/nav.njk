<nav>
    <ul>
        {%- for p in collections.all -%}
            {% if p.data.nav == true %}
                <li>
                    <a href="{{ p.url }}" {%if p.url == page.url %}class="active"{%endif%}>{{ p.data.title }}</a>
                </li>
            {% endif %}
        {%- endfor -%}
    </ul>
</nav>